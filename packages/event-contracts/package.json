{
  "name": "@elewate/event-contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Shared event/DTO schemas (versioned) — Architecture Blueprint §5. Zod schemas defined once per DTO, imported by both the API layer and the frontend (TDD §9.2).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@elewate/config": "workspace:*",
    "typescript": "^5.7.2"
  }
}
