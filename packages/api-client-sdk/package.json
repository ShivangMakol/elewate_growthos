{
  "name": "@elewate/api-client-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Typed client for web/mobile (Architecture Blueprint §5), wrapping core-api's REST + GraphQL surface.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@elewate/event-contracts": "workspace:*"
  },
  "devDependencies": {
    "@elewate/config": "workspace:*",
    "typescript": "^5.7.2"
  }
}
