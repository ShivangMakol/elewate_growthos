{
  "name": "@elewate/permissions-schema",
  "version": "0.0.0",
  "private": true,
  "description": "RBAC permission definitions — Architecture Blueprint §5. Shared between core-api's IAM authorization (RBAC+ABAC, Architecture §9) and any frontend that conditionally renders UI by permission.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@elewate/config": "workspace:*",
    "typescript": "^5.7.2"
  }
}
