{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "incremental": true,

    "baseUrl": ".",
    "paths": {
      "@elewate/ui-components": ["packages/ui-components/src"],
      "@elewate/ui-components/*": ["packages/ui-components/src/*"],
      "@elewate/api-client-sdk": ["packages/api-client-sdk/src"],
      "@elewate/api-client-sdk/*": ["packages/api-client-sdk/src/*"],
      "@elewate/event-contracts": ["packages/event-contracts/src"],
      "@elewate/event-contracts/*": ["packages/event-contracts/src/*"],
      "@elewate/permissions-schema": ["packages/permissions-schema/src"],
      "@elewate/permissions-schema/*": ["packages/permissions-schema/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next", "coverage"]
}
